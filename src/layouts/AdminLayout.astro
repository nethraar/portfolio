---
import '../styles/global.css';
interface Props { title?: string }
const { title = 'Admin' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Admin</title>
  </head>
  <body class="bg-zinc-900 text-zinc-100 font-sans antialiased min-h-screen">
    <nav class="bg-zinc-800 border-b border-zinc-700 px-6 py-3 flex items-center justify-between">
      <span class="font-semibold text-white">Portfolio Admin</span>
      <div class="flex gap-4 text-sm">
        <a href="/admin/dashboard" class="text-zinc-300 hover:text-white">Dashboard</a>
        <form method="POST" action="/api/auth/logout" class="inline">
          <button type="submit" class="text-zinc-400 hover:text-red-400">Logout</button>
        </form>
      </div>
    </nav>
    <main class="max-w-4xl mx-auto px-6 py-10">
      <slot />
    </main>
  </body>
</html>
