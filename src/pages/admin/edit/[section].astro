---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSession } from '../../../lib/auth';
import { getFileContent } from '../../../lib/github';

const session = getSession(Astro.request);
if (!session) return Astro.redirect('/admin?error=1');

const { section } = Astro.params;
const allowed = ['hero', 'featured', 'projects', 'slides', 'sheets'];
if (!allowed.includes(section!)) return Astro.redirect('/admin/dashboard');

const file = await getFileContent('src/data/content.json');
const content = file ? JSON.parse(file.content) : {};
const sectionData = content[section!];

const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');

const titles: Record<string, string> = {
  hero: 'Hero', featured: 'Featured', projects: 'Projects',
  slides: 'Slide Decks', sheets: 'Excel Sheets', apps: 'Live Apps'
};

const isFileSection = section === 'slides' || section === 'sheets';
const isArraySection = Array.isArray(sectionData) && !isFileSection;

const fieldDefs: Record<string, { label: string; type: string; placeholder?: string }[]> = {
  featured: [
    { label: 'Title', type: 'text' },
    { label: 'Type', type: 'text', placeholder: 'e.g. Project, Award, Publication' },
    { label: 'Description', type: 'textarea' },
    { label: 'Link', type: 'text', placeholder: 'https://...' },
  ],
  projects: [
    { label: 'Title', type: 'text' },
    { label: 'Description', type: 'textarea' },
    { label: 'Repo', type: 'text', placeholder: 'https://github.com/...' },
    { label: 'Demo', type: 'text', placeholder: 'https://...' },
    { label: 'Tags', type: 'text', placeholder: 'comma separated' },
  ],
  apps: [
    { label: 'Title', type: 'text' },
    { label: 'Description', type: 'textarea' },
    { label: 'Url', type: 'text', placeholder: 'https://...' },
  ],
};
---
<AdminLayout title={titles[section!]}>
  <div class="flex items-center gap-3 mb-8">
    <a href="/admin/dashboard" class="text-zinc-500 hover:text-white text-sm">← Dashboard</a>
    <span class="text-zinc-700">/</span>
    <h1 class="text-xl font-bold text-white">{titles[section!]}</h1>
  </div>

  {saved && <div class="bg-green-900/30 border border-green-700 text-green-300 text-sm px-4 py-3 rounded-lg mb-6">Saved and published.</div>}
  {error && <div class="bg-red-900/30 border border-red-700 text-red-300 text-sm px-4 py-3 rounded-lg mb-6">Error saving. Check GitHub token.</div>}

  <!-- HERO -->
  {section === 'hero' && (
    <form method="POST" action="/api/content/save" class="space-y-5">
      <input type="hidden" name="section" value="hero" />
      {Object.entries(sectionData).map(([key, val]) => (
        <div>
          <label class="block text-sm text-zinc-400 mb-1 capitalize">{key}</label>
          <input type="text" name={key} value={String(val)}
            class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-purple-500" />
        </div>
      ))}
      <button type="submit" class="px-5 py-2.5 bg-purple-800 hover:bg-purple-700 text-white text-sm rounded-lg transition">Save & Publish</button>
    </form>
  )}

  <!-- ARRAY SECTIONS (featured, projects, apps) -->
  {isArraySection && (
    <div class="space-y-8">

      <!-- Add new item -->
      <div class="bg-zinc-800 border border-zinc-700 rounded-xl p-6">
        <h2 class="font-semibold text-white mb-4">Add New</h2>
        <form method="POST" action="/api/content/add-item" enctype="multipart/form-data" class="space-y-4">
          <input type="hidden" name="section" value={section} />
          {(fieldDefs[section!] ?? []).map(field => (
            <div>
              <label class="block text-sm text-zinc-400 mb-1">{field.label}</label>
              {field.type === 'textarea' ? (
                <textarea name={field.label.toLowerCase()} rows={2} placeholder={field.placeholder ?? ''}
                  class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-purple-500 resize-none"></textarea>
              ) : (
                <input type="text" name={field.label.toLowerCase()} placeholder={field.placeholder ?? ''}
                  class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-purple-500" />
              )}
            </div>
          ))}
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Screenshot / Thumbnail <span class="text-zinc-600">(optional)</span></label>
            <input type="file" name="thumbnail" accept="image/*"
              class="w-full text-sm text-zinc-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-purple-800 file:text-white hover:file:bg-purple-700" />
          </div>
          <button type="submit" class="px-5 py-2.5 bg-purple-800 hover:bg-purple-700 text-white text-sm rounded-lg transition">Add & Publish</button>
        </form>
      </div>

      <!-- Existing items -->
      {(sectionData as any[]).length > 0 && (
        <div>
          <h2 class="font-semibold text-white mb-4">Existing ({(sectionData as any[]).length})</h2>
          <div class="space-y-3">
            {(sectionData as any[]).map((item: any, i: number) => (
              <div class="bg-zinc-800 border border-zinc-700 rounded-lg p-4 flex items-center gap-4">
                {item.thumbnail && (
                  <img src={`/uploads/${item.thumbnail}`} alt="" class="w-16 h-12 object-cover rounded" />
                )}
                {!item.thumbnail && (
                  <div class="w-16 h-12 bg-zinc-700 rounded flex items-center justify-center text-zinc-500 text-xs">No img</div>
                )}
                <div class="flex-1 min-w-0">
                  <p class="text-white text-sm font-medium truncate">{item.title}</p>
                  <p class="text-zinc-500 text-xs truncate">{item.description}</p>
                </div>
                <form method="POST" action="/api/content/remove-file">
                  <input type="hidden" name="section" value={section} />
                  <input type="hidden" name="index" value={String(i)} />
                  <button type="submit" class="text-xs text-red-400 hover:text-red-300 whitespace-nowrap">Remove</button>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  )}

  <!-- FILE SECTIONS (slides, sheets) -->
  {isFileSection && (
    <div class="space-y-8">
      <div class="bg-zinc-800 border border-zinc-700 rounded-xl p-6">
        <h2 class="font-semibold text-white mb-4">Upload New {section === 'slides' ? 'PPTX' : 'XLSX'}</h2>
        <form method="POST" action="/api/upload" enctype="multipart/form-data" class="space-y-4">
          <input type="hidden" name="section" value={section} />
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Title</label>
            <input type="text" name="title" required
              class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-purple-500" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Description</label>
            <textarea name="description" rows={2}
              class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-purple-500 resize-none"></textarea>
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">File ({section === 'slides' ? '.pptx' : '.xlsx'})</label>
            <input type="file" name="file" required accept={section === 'slides' ? '.pptx,.ppt' : '.xlsx,.xls'}
              class="w-full text-sm text-zinc-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-purple-800 file:text-white hover:file:bg-purple-700" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Screenshot / Thumbnail <span class="text-zinc-600">(optional)</span></label>
            <input type="file" name="thumbnail" accept="image/*"
              class="w-full text-sm text-zinc-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-zinc-700 file:text-zinc-300 hover:file:bg-zinc-600" />
          </div>
          <button type="submit" class="px-5 py-2.5 bg-purple-800 hover:bg-purple-700 text-white text-sm rounded-lg transition">Upload & Publish</button>
        </form>
      </div>

      {(sectionData as any[]).length > 0 && (
        <div>
          <h2 class="font-semibold text-white mb-4">Existing ({(sectionData as any[]).length})</h2>
          <div class="space-y-3">
            {(sectionData as any[]).map((item: any, i: number) => (
              <div class="bg-zinc-800 border border-zinc-700 rounded-lg p-4 flex items-center gap-4">
                {item.thumbnail ? (
                  <img src={`/uploads/${item.thumbnail}`} alt="" class="w-16 h-12 object-cover rounded" />
                ) : (
                  <div class="w-16 h-12 bg-zinc-700 rounded flex items-center justify-center text-zinc-500 text-xs">No img</div>
                )}
                <div class="flex-1 min-w-0">
                  <p class="text-white text-sm font-medium">{item.title}</p>
                  <p class="text-zinc-500 text-xs truncate">{item.filename}</p>
                </div>
                <form method="POST" action="/api/content/remove-file">
                  <input type="hidden" name="section" value={section} />
                  <input type="hidden" name="index" value={String(i)} />
                  <button type="submit" class="text-xs text-red-400 hover:text-red-300">Remove</button>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  )}
</AdminLayout>
