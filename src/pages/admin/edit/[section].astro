---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSession } from '../../../lib/auth';
import { getFileContent } from '../../../lib/github';

const session = getSession(Astro.request);
if (!session) return Astro.redirect('/admin?error=1');

const { section } = Astro.params;
const allowed = ['hero', 'featured', 'projects', 'slides', 'sheets', 'apps'];
if (!allowed.includes(section!)) return Astro.redirect('/admin/dashboard');

const file = await getFileContent('src/data/content.json');
const content = file ? JSON.parse(file.content) : {};
const sectionData = content[section!];

const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');

const titles: Record<string, string> = {
  hero: 'Hero',
  featured: 'Featured',
  projects: 'Projects',
  slides: 'Slide Decks',
  sheets: 'Excel Sheets',
  apps: 'Live Apps'
};

const isFileSection = section === 'slides' || section === 'sheets';
const isArraySection = Array.isArray(sectionData);
---
<AdminLayout title={titles[section!]}>
  <div class="flex items-center gap-3 mb-8">
    <a href="/admin/dashboard" class="text-zinc-500 hover:text-white text-sm">← Dashboard</a>
    <span class="text-zinc-700">/</span>
    <h1 class="text-xl font-bold text-white">{titles[section!]}</h1>
  </div>

  {saved && <div class="bg-green-900/30 border border-green-700 text-green-300 text-sm px-4 py-3 rounded-lg mb-6">Saved and published.</div>}
  {error && <div class="bg-red-900/30 border border-red-700 text-red-300 text-sm px-4 py-3 rounded-lg mb-6">Error saving. Check GitHub token.</div>}

  {section === 'hero' && (
    <form method="POST" action="/api/content/save" class="space-y-5">
      <input type="hidden" name="section" value="hero" />
      {Object.entries(sectionData).map(([key, val]) => (
        <div>
          <label class="block text-sm text-zinc-400 mb-1 capitalize">{key}</label>
          <input
            type="text"
            name={key}
            value={String(val)}
            class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-indigo-500"
          />
        </div>
      ))}
      <button type="submit" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm rounded-lg transition">Save & Publish</button>
    </form>
  )}

  {isArraySection && section !== 'slides' && section !== 'sheets' && (
    <div class="space-y-6">
      <div id="items-container" class="space-y-4">
        {(sectionData as any[]).map((item, i) => (
          <div class="bg-zinc-800 border border-zinc-700 rounded-xl p-5" data-item>
            <div class="flex justify-between items-start mb-4">
              <span class="text-sm text-zinc-400">Item {i + 1}</span>
              <button type="button" onclick="this.closest('[data-item]').remove()" class="text-xs text-red-400 hover:text-red-300">Remove</button>
            </div>
            {Object.entries(item).map(([key, val]) => (
              key !== 'id' && (
                <div class="mb-3">
                  <label class="block text-xs text-zinc-500 mb-1 capitalize">{key}</label>
                  {key === 'description' ? (
                    <textarea
                      name={`${section}[${i}][${key}]`}
                      rows={2}
                      class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-indigo-500 resize-none"
                    >{String(val)}</textarea>
                  ) : key === 'tags' ? (
                    <input
                      type="text"
                      name={`${section}[${i}][${key}]`}
                      value={(val as string[]).join(', ')}
                      placeholder="comma separated"
                      class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-indigo-500"
                    />
                  ) : (
                    <input
                      type="text"
                      name={`${section}[${i}][${key}]`}
                      value={String(val)}
                      class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-indigo-500"
                    />
                  )}
                </div>
              )
            ))}
          </div>
        ))}
      </div>

      <button type="button" id="add-btn" class="text-sm text-indigo-400 hover:text-indigo-300 border border-dashed border-zinc-700 hover:border-indigo-500 px-4 py-2 rounded-lg w-full transition">
        + Add item
      </button>

      <form id="save-form" method="POST" action="/api/content/save-array">
        <input type="hidden" name="section" value={section} />
        <input type="hidden" name="data" id="form-data" />
        <button type="submit" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm rounded-lg transition">Save & Publish</button>
      </form>
    </div>
  )}

  {isFileSection && (
    <div class="space-y-8">
      <!-- Upload new file -->
      <div class="bg-zinc-800 border border-zinc-700 rounded-xl p-6">
        <h2 class="font-semibold text-white mb-4">Upload New {section === 'slides' ? 'PPTX' : 'XLSX'}</h2>
        <form method="POST" action="/api/upload" enctype="multipart/form-data" class="space-y-4">
          <input type="hidden" name="section" value={section} />
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Title</label>
            <input type="text" name="title" required class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-indigo-500" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Description</label>
            <textarea name="description" rows={2} class="w-full bg-zinc-900 border border-zinc-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-indigo-500 resize-none"></textarea>
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">File ({section === 'slides' ? '.pptx' : '.xlsx'})</label>
            <input type="file" name="file" required accept={section === 'slides' ? '.pptx,.ppt' : '.xlsx,.xls'} class="w-full text-sm text-zinc-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-indigo-600 file:text-white hover:file:bg-indigo-500" />
          </div>
          <button type="submit" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm rounded-lg transition">Upload & Publish</button>
        </form>
      </div>

      <!-- Existing files -->
      {(sectionData as any[]).length > 0 && (
        <div>
          <h2 class="font-semibold text-white mb-4">Existing ({(sectionData as any[]).length})</h2>
          <div class="space-y-3">
            {(sectionData as any[]).map((item: any, i: number) => (
              <div class="bg-zinc-800 border border-zinc-700 rounded-lg p-4 flex items-center justify-between">
                <div>
                  <p class="text-white text-sm font-medium">{item.title}</p>
                  <p class="text-zinc-500 text-xs">{item.filename}</p>
                </div>
                <form method="POST" action="/api/content/remove-file">
                  <input type="hidden" name="section" value={section} />
                  <input type="hidden" name="index" value={String(i)} />
                  <button type="submit" class="text-xs text-red-400 hover:text-red-300">Remove</button>
                </form>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  )}
</AdminLayout>

<script>
  // Serialize items to JSON for array sections
  const saveForm = document.getElementById('save-form');
  if (saveForm) {
    saveForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const items: any[] = [];
      document.querySelectorAll('[data-item]').forEach((el, i) => {
        const item: Record<string, any> = { id: Date.now().toString() + i };
        el.querySelectorAll('input, textarea').forEach((input) => {
          const inp = input as HTMLInputElement;
          const match = inp.name.match(/\[(\w+)\]$/);
          if (match) {
            const key = match[1];
            if (key === 'tags') {
              item[key] = inp.value.split(',').map((t: string) => t.trim()).filter(Boolean);
            } else {
              item[key] = inp.value;
            }
          }
        });
        items.push(item);
      });
      (document.getElementById('form-data') as HTMLInputElement).value = JSON.stringify(items);
      (saveForm as HTMLFormElement).submit();
    });
  }

  // Add item button — clones template from first item or creates blank
  const addBtn = document.getElementById('add-btn');
  const container = document.getElementById('items-container');
  if (addBtn && container) {
    addBtn.addEventListener('click', () => {
      const existing = container.querySelector('[data-item]');
      if (existing) {
        const clone = existing.cloneNode(true) as HTMLElement;
        clone.querySelectorAll('input, textarea').forEach((inp) => {
          (inp as HTMLInputElement).value = '';
        });
        const removeBtn = clone.querySelector('button');
        if (removeBtn) removeBtn.onclick = () => clone.remove();
        container.appendChild(clone);
      }
    });
  }
</script>
