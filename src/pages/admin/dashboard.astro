---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import { getFileContent } from '../../lib/github';

const session = getSession(Astro.request);
if (!session) return Astro.redirect('/admin?error=1');

const file = await getFileContent('src/data/content.json');
const content = file ? JSON.parse(file.content) : null;
---
<AdminLayout title="Dashboard">
  <h1 class="text-2xl font-bold text-white mb-2">Dashboard</h1>
  <p class="text-zinc-500 mb-10">Manage your portfolio content. Changes publish to GitHub automatically.</p>

  <div class="grid gap-4 sm:grid-cols-2">
    <a href="/admin/edit/hero" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-xl p-6 transition block">
      <h2 class="font-semibold text-white mb-1">Hero</h2>
      <p class="text-zinc-400 text-sm">Name, tagline, social links</p>
    </a>
    <a href="/admin/edit/featured" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-xl p-6 transition block">
      <h2 class="font-semibold text-white mb-1">Featured</h2>
      <p class="text-zinc-400 text-sm">{content?.featured?.length ?? 0} items</p>
    </a>
    <a href="/admin/edit/projects" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-xl p-6 transition block">
      <h2 class="font-semibold text-white mb-1">Projects</h2>
      <p class="text-zinc-400 text-sm">{content?.projects?.length ?? 0} repos</p>
    </a>
    <a href="/admin/edit/slides" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-xl p-6 transition block">
      <h2 class="font-semibold text-white mb-1">Slide Decks</h2>
      <p class="text-zinc-400 text-sm">{content?.slides?.length ?? 0} decks · Upload PPTX</p>
    </a>
    <a href="/admin/edit/sheets" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-xl p-6 transition block">
      <h2 class="font-semibold text-white mb-1">Excel Sheets</h2>
      <p class="text-zinc-400 text-sm">{content?.sheets?.length ?? 0} sheets · Upload XLSX</p>
    </a>
    <a href="/admin/edit/apps" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-xl p-6 transition block">
      <h2 class="font-semibold text-white mb-1">Live Apps</h2>
      <p class="text-zinc-400 text-sm">{content?.apps?.length ?? 0} apps</p>
    </a>
  </div>

  <div class="mt-10 p-4 bg-zinc-800/50 border border-zinc-700 rounded-lg text-sm text-zinc-400">
    Logged in as <span class="text-white">{session.email}</span>
  </div>
</AdminLayout>
