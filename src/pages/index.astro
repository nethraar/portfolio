---
import Layout from '../layouts/Layout.astro';
import contentJson from '../data/content.json';
const c = contentJson;
---
<Layout title="Nethrashri Ramesh">

<style>
  /* Palette */
  :root {
    --navy-900: #001233;
    --navy-800: #001845;
    --navy-700: #002855;
    --navy-600: #023E7D;
    --blue-500: #0353A4;
    --blue-400: #0466C8;
    --slate-600: #33415C;
    --slate-500: #5C677D;
    --slate-400: #7D8597;
    --slate-300: #979DAC;
    --light-bg:  #F4F6F9;
    --light-bg2: #EEF1F6;
  }

  /* Typography */
  .font-display { font-family: 'Playfair Display', Georgia, serif; }

  /* Nav */
  .nav-wrap { background: rgba(0,18,51,0.92); border-bottom: 1px solid rgba(255,255,255,0.06); backdrop-filter: blur(12px); }

  /* Buttons — sharp */
  .btn-primary {
    background: var(--blue-400);
    color: #fff;
    padding: 11px 24px;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    display: inline-block;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--blue-500); }
  .btn-outline {
    border: 1px solid rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.7);
    padding: 11px 24px;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: inline-block;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover { border-color: #fff; color: #fff; }

  /* Section header line reveal */
  .section-line {
    width: 0;
    height: 2px;
    background: var(--blue-400);
    transition: width 0.8s cubic-bezier(0.4,0,0.2,1);
    margin-top: 8px;
    margin-bottom: 32px;
  }
  .section-line.revealed { width: 48px; }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  /* Light cards — sharp */
  .card-light {
    background: #fff;
    border: 1px solid #dde3ed;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .card-light:hover {
    border-color: var(--blue-400);
    box-shadow: 0 6px 24px rgba(4,102,200,0.10);
    transform: translateY(-2px);
  }

  /* Dark cards */
  .card-dark {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    transition: border-color 0.2s, transform 0.2s;
  }
  .card-dark:hover { border-color: var(--blue-400); transform: translateY(-2px); }

  /* Tag */
  .tag { background: #E8EEF7; color: var(--navy-600); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; padding: 3px 8px; }

  /* Divider */
  .light-divider { border-top: 1px solid #dde3ed; }

  /* Counter animation */
  .stat-num { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; color: var(--blue-400); }

  /* Featured horizontal scroll */
  .feat-scroll { display: flex; gap: 24px; overflow-x: auto; padding-bottom: 8px; }
  .feat-scroll::-webkit-scrollbar { height: 4px; }
  .feat-scroll::-webkit-scrollbar-track { background: rgba(255,255,255,0.05); }
  .feat-scroll::-webkit-scrollbar-thumb { background: var(--blue-500); }

  /* Consulting ticker line */
  @keyframes slideRight { from { transform: scaleX(0); transform-origin: left; } to { transform: scaleX(1); transform-origin: left; } }
  .hero-line { height: 1px; background: var(--blue-400); animation: slideRight 1.2s cubic-bezier(0.4,0,0.2,1) 0.6s both; }

  /* Hero fade in */
  @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
  .hero-1 { animation: fadeUp 0.8s ease 0.1s both; }
  .hero-2 { animation: fadeUp 0.8s ease 0.3s both; }
  .hero-3 { animation: fadeUp 0.8s ease 0.5s both; }
  .hero-4 { animation: fadeUp 0.8s ease 0.7s both; }
  .hero-5 { animation: fadeUp 0.8s ease 0.9s both; }
</style>

<!-- Nav -->
<header class="fixed top-0 inset-x-0 z-50 nav-wrap">
  <nav class="max-w-6xl mx-auto px-8 py-4 flex items-center justify-between">
    <span class="font-display font-semibold text-white tracking-wide text-sm">NR</span>
    <div class="flex gap-8 text-xs font-medium tracking-widest uppercase" style="color:var(--slate-300)">
      <a href="#featured" class="hover:text-white transition">Featured</a>
      <a href="#slides" class="hover:text-white transition">Slides</a>
      <a href="#sheets" class="hover:text-white transition">Sheets</a>
      <a href="#projects" class="hover:text-white transition">Projects</a>
      <a href="#contact" class="hover:text-white transition">Contact</a>
    </div>
  </nav>
</header>

<!-- Hero -->
<section class="min-h-screen flex flex-col justify-center px-8 pt-20 relative overflow-hidden" style="background: linear-gradient(160deg, #001233 60%, #001845 100%);">
  <!-- Background grid -->
  <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgba(4,102,200,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(4,102,200,0.04) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="max-w-6xl mx-auto w-full relative">
    <p class="hero-1 text-xs font-medium tracking-widest uppercase mb-6" style="color:var(--blue-400)">Portfolio · {new Date().getFullYear()}</p>

    <h1 class="hero-2 font-display text-6xl sm:text-8xl font-700 text-white leading-none mb-2" style="font-weight:700; letter-spacing:-0.02em">{c.hero.name}</h1>

    <div class="hero-line w-24 mb-6 mt-4"></div>

    <p class="hero-3 text-xl mb-2 font-light" style="color:var(--slate-300); letter-spacing:0.01em">{c.hero.tagline}</p>
    <p class="hero-4 max-w-2xl text-sm leading-relaxed mb-10" style="color:var(--slate-500)">{c.hero.subtagline}</p>

    <!-- Contact inline under name -->
    <div class="hero-4 flex gap-6 flex-wrap mb-10" style="color:var(--slate-400)">
      <a href={`mailto:${c.hero.email}`} class="flex items-center gap-2 text-xs tracking-wide hover:text-white transition" style="color:var(--slate-300)">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        {c.hero.email}
      </a>
      <a href={c.hero.linkedin} target="_blank" class="flex items-center gap-2 text-xs tracking-wide hover:text-white transition" style="color:var(--slate-300)">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a href={c.hero.github} target="_blank" class="flex items-center gap-2 text-xs tracking-wide hover:text-white transition" style="color:var(--slate-300)">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>

    <div class="hero-5 flex gap-4">
      <a href="#contact" class="btn-primary">Get in touch</a>
      <a href="#projects" class="btn-outline">See work</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="color:var(--slate-500)">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-12 overflow-hidden" style="background:rgba(255,255,255,0.1)">
      <div style="width:1px;height:100%;background:var(--blue-400);animation:scrollDrop 1.5s ease infinite"></div>
    </div>
  </div>
</section>

<style>
  @keyframes scrollDrop { 0%{transform:translateY(-100%)} 100%{transform:translateY(200%)} }
</style>

<!-- Featured (dark navy) -->
<section id="featured" style="background: var(--navy-800); padding: 96px 0;">
  <div class="max-w-6xl mx-auto px-8">
    <div class="reveal">
      <p class="text-xs font-medium tracking-widest uppercase mb-1" style="color:var(--blue-400)">Spotlight</p>
      <h2 class="font-display text-4xl font-semibold text-white" style="letter-spacing:-0.01em">Featured</h2>
      <div class="section-line"></div>
    </div>
    {c.featured.length === 0 ? (
      <p class="reveal" style="color:var(--slate-500); font-style:italic">No featured items yet. Add from admin panel.</p>
    ) : (
      <div class="feat-scroll">
        {c.featured.map((item: any, i: number) => (
          <div class={`card-dark reveal reveal-delay-${Math.min(i+1,4)}`} style="min-width:280px; flex-shrink:0; overflow:hidden">
            {item.thumbnail && <img src={`/uploads/${item.thumbnail}`} alt={item.title} style="width:100%;height:160px;object-fit:cover;display:block" />}
            <div style="padding:24px">
              <p style="font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue-400);margin-bottom:8px">{item.type}</p>
              <h3 style="font-family:'Playfair Display',serif;font-size:1.1rem;color:#fff;margin-bottom:8px;font-weight:600">{item.title}</h3>
              <p style="font-size:0.8125rem;color:var(--slate-400);line-height:1.6;margin-bottom:16px">{item.description}</p>
              {item.link && <a href={item.link} target="_blank" style="font-size:0.75rem;color:var(--blue-400);text-transform:uppercase;letter-spacing:0.06em;font-weight:500">View →</a>}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<!-- LIGHT SECTION -->
<div style="background:var(--light-bg)">

<!-- Slides -->
<section id="slides" style="padding:96px 0">
  <div class="max-w-6xl mx-auto px-8">
    <div class="reveal">
      <p class="text-xs font-medium tracking-widest uppercase mb-1" style="color:var(--blue-500)">Presentations</p>
      <h2 class="font-display text-4xl font-semibold" style="color:var(--navy-900);letter-spacing:-0.01em">Slide Decks</h2>
      <div class="section-line" style="background:var(--blue-500)"></div>
    </div>
    {c.slides.length === 0 ? (
      <p class="reveal" style="color:var(--slate-400);font-style:italic">No slides added yet.</p>
    ) : (
      <div class="grid gap-6" style="grid-template-columns:repeat(auto-fill,minmax(340px,1fr))">
        {c.slides.map((s: any, i: number) => (
          <div class={`card-light reveal reveal-delay-${Math.min(i+1,4)}`} style="overflow:hidden">
            {s.thumbnail ? (
              <img src={`/uploads/${s.thumbnail}`} alt={s.title} style="width:100%;height:180px;object-fit:cover;display:block" />
            ) : (
              <div style="aspect-ratio:16/9;background:#e2e8f0">
                <iframe src={`https://view.officeapps.live.com/op/embed.aspx?src=${encodeURIComponent(`https://raw.githubusercontent.com/nethraar/portfolio/main/public/uploads/${s.filename}`)}`} width="100%" height="100%" frameborder="0" style="display:block;width:100%;height:100%" />
              </div>
            )}
            <div style="padding:24px">
              <h3 style="font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--navy-900);margin-bottom:6px;font-weight:600">{s.title}</h3>
              <p style="font-size:0.8125rem;color:var(--slate-500);line-height:1.6;margin-bottom:16px">{s.description}</p>
              <a href={`/uploads/${s.filename}`} download style="font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--blue-500)">Download →</a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<div class="max-w-6xl mx-auto px-8"><div class="light-divider"></div></div>

<!-- Sheets -->
<section id="sheets" style="padding:96px 0">
  <div class="max-w-6xl mx-auto px-8">
    <div class="reveal">
      <p class="text-xs font-medium tracking-widest uppercase mb-1" style="color:var(--navy-600)">Analysis</p>
      <h2 class="font-display text-4xl font-semibold" style="color:var(--navy-900);letter-spacing:-0.01em">Excel Sheets</h2>
      <div class="section-line" style="background:var(--navy-600)"></div>
    </div>
    {c.sheets.length === 0 ? (
      <p class="reveal" style="color:var(--slate-400);font-style:italic">No sheets added yet.</p>
    ) : (
      <div class="grid gap-6" style="grid-template-columns:repeat(auto-fill,minmax(340px,1fr))">
        {c.sheets.map((s: any, i: number) => (
          <div class={`card-light reveal reveal-delay-${Math.min(i+1,4)}`} style="overflow:hidden">
            {s.thumbnail ? (
              <img src={`/uploads/${s.thumbnail}`} alt={s.title} style="width:100%;height:180px;object-fit:cover;display:block" />
            ) : (
              <div style="aspect-ratio:16/9;background:#e2e8f0">
                <iframe src={`https://view.officeapps.live.com/op/embed.aspx?src=${encodeURIComponent(`https://raw.githubusercontent.com/nethraar/portfolio/main/public/uploads/${s.filename}`)}`} width="100%" height="100%" frameborder="0" style="display:block;width:100%;height:100%" />
              </div>
            )}
            <div style="padding:24px">
              <h3 style="font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--navy-900);margin-bottom:6px;font-weight:600">{s.title}</h3>
              <p style="font-size:0.8125rem;color:var(--slate-500);line-height:1.6;margin-bottom:16px">{s.description}</p>
              <a href={`/uploads/${s.filename}`} download style="font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--navy-600)">Download →</a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<div class="max-w-6xl mx-auto px-8"><div class="light-divider"></div></div>

<!-- Projects -->
<section id="projects" style="padding:96px 0">
  <div class="max-w-6xl mx-auto px-8">
    <div class="reveal">
      <p class="text-xs font-medium tracking-widest uppercase mb-1" style="color:var(--slate-500)">Work</p>
      <h2 class="font-display text-4xl font-semibold" style="color:var(--navy-900);letter-spacing:-0.01em">Projects</h2>
      <div class="section-line" style="background:var(--slate-500)"></div>
    </div>
    <div class="grid gap-6" style="grid-template-columns:repeat(auto-fill,minmax(340px,1fr))">
      {c.projects.map((p: any, i: number) => (
        <div class={`card-light reveal reveal-delay-${Math.min(i+1,4)}`} style="overflow:hidden">
          {p.thumbnail && <img src={`/uploads/${p.thumbnail}`} alt={p.title} style="width:100%;height:160px;object-fit:cover;display:block" />}
          <div style="padding:24px">
            <h3 style="font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--navy-900);margin-bottom:8px;font-weight:600">{p.title}</h3>
            <p style="font-size:0.8125rem;color:var(--slate-500);line-height:1.6;margin-bottom:16px">{p.description}</p>
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px">
              {p.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div style="display:flex;gap:20px">
              {p.repo && <a href={p.repo} target="_blank" style="font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--slate-500)">GitHub →</a>}
              {p.demo && <a href={p.demo} target="_blank" style="font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--blue-500)">Live demo →</a>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="max-w-6xl mx-auto px-8"><div class="light-divider"></div></div>

<!-- Contact -->
<section id="contact" style="padding:96px 0">
  <div class="max-w-6xl mx-auto px-8">
    <div class="reveal">
      <p class="text-xs font-medium tracking-widest uppercase mb-1" style="color:var(--slate-500)">Connect</p>
      <h2 class="font-display text-4xl font-semibold" style="color:var(--navy-900);letter-spacing:-0.01em">Contact</h2>
      <div class="section-line" style="background:var(--slate-500)"></div>
    </div>
    <div class="reveal reveal-delay-1" style="display:flex;gap:40px;flex-wrap:wrap">
      <a href={`mailto:${c.hero.email}`} class="flex items-center gap-3 transition hover:opacity-70" style="color:var(--navy-700)">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        <span style="font-size:0.875rem">{c.hero.email}</span>
      </a>
      <a href={c.hero.linkedin} target="_blank" class="flex items-center gap-3 transition hover:opacity-70" style="color:var(--navy-700)">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        <span style="font-size:0.875rem">LinkedIn</span>
      </a>
      <a href={c.hero.github} target="_blank" class="flex items-center gap-3 transition hover:opacity-70" style="color:var(--navy-700)">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span style="font-size:0.875rem">GitHub</span>
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer style="border-top:1px solid #dde3ed;padding:32px 0;text-align:center;font-size:0.75rem;color:var(--slate-400);letter-spacing:0.04em">
  © {new Date().getFullYear()} Nethrashri Ramesh · All rights reserved
</footer>

</div><!-- end light -->

<script>
  // Intersection Observer for .reveal elements
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        // Also trigger section-line reveal
        const line = entry.target.querySelector?.('.section-line');
        if (line) line.classList.add('revealed');
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Trigger section-line for parent reveals
  const lineObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.section-line').forEach(el => lineObserver.observe(el));
</script>

</Layout>
