---
import Layout from '../layouts/Layout.astro';
import contentJson from '../data/content.json';
const c = contentJson;
---
<Layout title="Nethrashri Ramesh">

  <style>
    :root {
      --purple-deep:    #2d1b4e;
      --purple-mid:     #3d2668;
      --purple-muted:   #6b5a8e;
      --purple-light:   #9b8ab8;
      --purple-faint:   #1e1230;
    }
    .section-divider { border-color: #2a1f3d; }
    .card { background: #150d2a; border: 1px solid #2a1f3d; }
    .card:hover { border-color: var(--purple-muted); }
    .tag { background: #1e1230; color: #9b8ab8; }
    .nav-bg { background: rgba(15, 8, 28, 0.85); border-color: #2a1f3d; }
    .featured-bg { background: linear-gradient(135deg, #1e1230 0%, #2d1b4e 100%); }
    .btn-primary { background: #3d2668; }
    .btn-primary:hover { background: #4d3278; }
    .btn-outline { border-color: #2a1f3d; color: #9b8ab8; }
    .btn-outline:hover { border-color: #6b5a8e; color: #c4b8dc; }
  </style>

  <!-- Nav -->
  <header class="fixed top-0 inset-x-0 z-50 nav-bg backdrop-blur border-b">
    <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <span class="font-bold text-white tracking-tight">NR</span>
      <div class="flex gap-6 text-sm" style="color: var(--purple-light)">
        <a href="#featured" class="hover:text-white transition">Featured</a>
        <a href="#slides" class="hover:text-white transition">Slides</a>
        <a href="#sheets" class="hover:text-white transition">Sheets</a>
        <a href="#projects" class="hover:text-white transition">Projects</a>
        <a href="#apps" class="hover:text-white transition">Apps</a>
        <a href="#contact" class="hover:text-white transition">Contact</a>
      </div>
    </nav>
  </header>

  <!-- Hero -->
  <section class="min-h-screen flex flex-col justify-center max-w-5xl mx-auto px-6 pt-20" style="background: #0f081c;">
    <p class="text-sm font-medium tracking-widest uppercase mb-4" style="color: var(--purple-muted)">Portfolio</p>
    <h1 class="text-5xl sm:text-7xl font-bold text-white mb-4 leading-tight">{c.hero.name}</h1>
    <p class="text-2xl mb-3" style="color: #c4b8dc">{c.hero.tagline}</p>
    <p class="max-w-xl mb-10" style="color: var(--purple-muted)">{c.hero.subtagline}</p>
    <div class="flex gap-4 flex-wrap">
      <a href="#contact" class="btn-primary px-5 py-2.5 text-white rounded-lg text-sm font-medium transition">Get in touch</a>
      <a href="#projects" class="btn-outline px-5 py-2.5 rounded-lg text-sm font-medium transition border">See work</a>
    </div>
  </section>

  <!-- Featured — horizontal band, different bg -->
  <section id="featured" class="featured-bg py-24">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-white mb-1">Featured</h2>
      <p class="mb-10 text-sm" style="color: #8b7cb0">Highlighted work</p>
      {c.featured.length === 0 ? (
        <p style="color: #4a3a6a; font-style: italic">No featured items yet. Add them from the admin panel.</p>
      ) : (
        <div class="flex gap-6 overflow-x-auto pb-2">
          {c.featured.map((item: any) => (
            <div class="card rounded-xl overflow-hidden min-w-72 flex-shrink-0 hover:border-purple-600 transition">
              {item.thumbnail && <img src={`/uploads/${item.thumbnail}`} alt={item.title} class="w-full h-40 object-cover" />}
              <div class="p-6">
                <p class="text-xs uppercase tracking-widest mb-2" style="color: #8b7cb0">{item.type}</p>
                <h3 class="text-lg font-semibold text-white mb-2">{item.title}</h3>
                <p class="text-sm mb-4" style="color: #7a6b9a">{item.description}</p>
                {item.link && <a href={item.link} target="_blank" style="color: var(--purple-light)" class="text-sm hover:text-white">View →</a>}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Slides -->
  <section id="slides" class="max-w-5xl mx-auto px-6 py-24">
    <h2 class="text-3xl font-bold mb-1" style="color: #c4a8e8">Slide Decks</h2>
    <p class="mb-10 text-sm" style="color: #6b5a8e">Presentations and decks</p>
    {c.slides.length === 0 ? (
      <p style="color: #3a2a5a; font-style: italic">No slides added yet.</p>
    ) : (
      <div class="grid gap-8 sm:grid-cols-2">
        {c.slides.map((s: any) => (
          <div class="card rounded-xl overflow-hidden">
            <div class="aspect-video bg-zinc-900">
              <iframe
                src={`https://view.officeapps.live.com/op/embed.aspx?src=${encodeURIComponent(`https://raw.githubusercontent.com/nethraar/portfolio/main/public/uploads/${s.filename}`)}`}
                width="100%" height="100%" frameborder="0" class="w-full h-full"
              />
            </div>
            <div class="p-5">
              <h3 class="font-semibold text-white mb-1">{s.title}</h3>
              <p class="text-sm mb-3" style="color: #7a6b9a">{s.description}</p>
              <a href={`/uploads/${s.filename}`} download style="color: var(--purple-light)" class="text-xs hover:text-white">Download →</a>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>

  <!-- Sheets -->
  <section id="sheets" class="py-24 border-t section-divider" style="background: #0d0820;">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-1" style="color: #a8c8e8">Excel Sheets</h2>
      <p class="mb-10 text-sm" style="color: #4a6a8e">Spreadsheets and analysis</p>
      {c.sheets.length === 0 ? (
        <p style="color: #2a3a5a; font-style: italic">No sheets added yet.</p>
      ) : (
        <div class="grid gap-8 sm:grid-cols-2">
          {c.sheets.map((s: any) => (
            <div class="card rounded-xl overflow-hidden">
              <div class="aspect-video bg-zinc-900">
                <iframe
                  src={`https://view.officeapps.live.com/op/embed.aspx?src=${encodeURIComponent(`https://raw.githubusercontent.com/nethraar/portfolio/main/public/uploads/${s.filename}`)}`}
                  width="100%" height="100%" frameborder="0" class="w-full h-full"
                />
              </div>
              <div class="p-5">
                <h3 class="font-semibold text-white mb-1">{s.title}</h3>
                <p class="text-sm mb-3" style="color: #7a6b9a">{s.description}</p>
                <a href={`/uploads/${s.filename}`} download style="color: #a8c8e8" class="text-xs hover:text-white">Download →</a>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="max-w-5xl mx-auto px-6 py-24">
    <h2 class="text-3xl font-bold mb-1" style="color: #b8e8c8">Projects</h2>
    <p class="mb-10 text-sm" style="color: #4a7a5e">GitHub repositories</p>
    <div class="grid gap-6 sm:grid-cols-2">
      {c.projects.map((p: any) => (
        <div class="card rounded-xl overflow-hidden transition" style="transition: border-color 0.2s">
          {p.thumbnail && <img src={`/uploads/${p.thumbnail}`} alt={p.title} class="w-full h-40 object-cover" />}
          <div class="p-6">
          <h3 class="text-lg font-semibold text-white mb-2">{p.title}</h3>
          <p class="text-sm mb-4" style="color: #7a6b9a">{p.description}</p>
          <div class="flex gap-2 flex-wrap mb-4">
            {p.tags.map((tag: string) => (
              <span class="tag text-xs px-2 py-1 rounded">{tag}</span>
            ))}
          </div>
          <div class="flex gap-4">
            {p.repo && <a href={p.repo} target="_blank" style="color: #9b8ab8" class="text-sm hover:text-white transition">GitHub →</a>}
            {p.demo && <a href={p.demo} target="_blank" style="color: #b8e8c8" class="text-sm hover:text-white transition">Live demo →</a>}
          </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Apps -->
  <section id="apps" class="py-24 border-t section-divider" style="background: #0d0820;">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-1" style="color: #e8c8a8">Live Apps</h2>
      <p class="mb-10 text-sm" style="color: #7a5a3a">Deployed applications</p>
      {c.apps.length === 0 ? (
        <p style="color: #3a2a1a; font-style: italic">No apps added yet.</p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2">
          {c.apps.map((a: any) => (
            <div class="card rounded-xl overflow-hidden transition">
              {a.thumbnail && <img src={`/uploads/${a.thumbnail}`} alt={a.title} class="w-full h-40 object-cover" />}
              <div class="p-6">
                <h3 class="text-lg font-semibold text-white mb-2">{a.title}</h3>
                <p class="text-sm mb-4" style="color: #7a6b9a">{a.description}</p>
                <a href={a.url} target="_blank" class="btn-primary px-4 py-2 text-white text-sm rounded-lg transition inline-block">Open app →</a>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="max-w-5xl mx-auto px-6 py-24">
    <h2 class="text-3xl font-bold text-white mb-1">Contact</h2>
    <p class="mb-10 text-sm" style="color: #6b5a8e">Get in touch</p>
    <div class="flex gap-8 flex-wrap">
      <a href={`mailto:${c.hero.email}`} class="flex items-center gap-2 transition hover:text-white" style="color: #9b8ab8">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        {c.hero.email}
      </a>
      <a href={c.hero.linkedin} target="_blank" class="flex items-center gap-2 transition hover:text-white" style="color: #9b8ab8">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a href={c.hero.github} target="_blank" class="flex items-center gap-2 transition hover:text-white" style="color: #9b8ab8">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </section>

  <footer class="py-8 text-center text-sm border-t section-divider" style="color: #3a2a5a">
    © {new Date().getFullYear()} Nethrashri Ramesh
  </footer>

</Layout>
